# ============================================================
# AdorniLeaks — Variables de Entorno (EJEMPLO)
# Copiar como .env y completar con valores reales
# NUNCA subir el archivo .env a Git
# ============================================================

# --- Groq (AI gratuita) ---
# Conseguir en: https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXX

# --- Supabase ---
# Conseguir en: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXX

# --- Configuración del agente ---
# Cantidad máxima de artículos a procesar por ejecución
MAX_ARTICULOS=50
# Score mínimo para guardar un artículo (1-10)
SCORE_MINIMO=6
# Modelo de Groq a usar
GROQ_MODEL=llama-3.3-70b-versatile
